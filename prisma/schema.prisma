// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
//
// Prisma 7: connection URLs live in prisma.config.ts (not in this file).
// Runtime app queries use pg + DATABASE_URL (see src/lib/postgres.ts).
// Careers resumes are stored in Postgres as BYTEA (no external file storage).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Career applications — candidate metadata + resume binary in Postgres.
model CareerApplication {
  id              String   @id @default(cuid())
  fullName        String   @map("full_name")
  email           String
  whatsapp        String
  interestedRole  String   @map("interested_role")
  message         String?
  resumeFileName  String   @map("resume_file_name")
  resumeMimeType  String   @map("resume_mime_type")
  resumeSizeBytes Int      @map("resume_size_bytes")
  resumeFileData  Bytes    @map("resume_file_data")
  source          String
  status          String   @default("new")
  adminNotes      String?  @map("admin_notes")
  submittedAt     DateTime @default(now()) @map("submitted_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([submittedAt(sort: Desc)])
  @@index([status])
  @@map("career_applications")
}
