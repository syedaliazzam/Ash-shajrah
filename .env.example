# =============================================================================
# Ash-Shajrah Learning Hub — environment template
# Copy to `.env` locally. Never commit real `.env` values.
# Careers uses Supabase Postgres only (candidate details + resume BYTEA).
# =============================================================================

# --- Postgres (Supabase) ---
# Pooled runtime URL (port 6543 + pgbouncer). Used by the Next.js app (pg).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"

# Direct/session URL (port 5432). Used for migrations / table setup scripts.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Do NOT prefix either database URL with NEXT_PUBLIC_

# --- SMTP (contact, registration, careers notifications) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
CONTACT_TO_EMAIL=admission.ashshajrah@gmail.com
CAREERS_EMAIL_TO=admission.ashshajrah@gmail.com

# --- LMS Admin Portal (career applications) ---
LMS_ADMIN_PASSWORD=
LMS_ADMIN_SECRET=

# --- Google Sheets (inquiries / registration only — NOT used for careers) ---
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEET_RANGE=Inquiries!A:E

# --- Public site ---
NEXT_PUBLIC_SITE_URL=https://ashshajrah.com
NEXT_PUBLIC_ASH_SHAJRAH_FACEBOOK_URL=
